{
  "name": "les-backend-livraria",
  "version": "1.0.0",
  "description": "Backend do e-commerce de livros (LES) com autenticação, registro de clientes e controle de acesso.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand src/tests/unitarios",
    "test:int": "jest --runInBand src/tests/integracao",
    "test:unit:admin": "jest --runInBand src/tests/unitarios/admin",
    "test:int:admin": "jest --runInBand src/tests/integracao/admin",
    "test:dominio:admin": "npm run test:unit:admin && npm run test:int:admin",
    "test:unit:clientes": "jest --runInBand src/tests/unitarios/clientes",
    "test:int:clientes": "jest --runInBand src/tests/integracao/clientes",
    "test:dominio:clientes": "npm run test:unit:clientes && npm run test:int:clientes",
    "test:unit:vendas": "jest --runInBand src/tests/unitarios/vendas",
    "test:int:vendas": "jest --runInBand src/tests/integracao/vendas",
    "test:dominio:vendas": "npm run test:unit:vendas && npm run test:int:vendas",
    "test:unit:pagamentos": "jest --runInBand src/tests/unitarios/pagamentos",
    "test:int:pagamentos": "jest --runInBand src/tests/integracao/pagamentos",
    "test:dominio:pagamentos": "npm run test:unit:pagamentos && npm run test:int:pagamentos",
    "test:unit:entrega": "jest --runInBand src/tests/unitarios/entrega",
    "test:int:entrega": "jest --runInBand src/tests/integracao/entrega",
    "test:dominio:entrega": "npm run test:unit:entrega && npm run test:int:entrega",
    "test:unit:frete": "jest --runInBand src/tests/unitarios/frete",
    "test:int:frete": "jest --runInBand src/tests/integracao/frete",
    "test:dominio:frete": "npm run test:unit:frete && npm run test:int:frete",
    "test:unit:usuarios": "jest --runInBand src/tests/unitarios/usuarios",
    "test:unit:utils": "jest --runInBand src/tests/unitarios/utils src/tests/unitarios/formatacao.util.test.ts",
    "test:unit:infra": "jest --runInBand src/tests/unitarios/infra",
    "test:auditoria": "jest --runInBand src/tests/auditoria-condicionais.test.ts",
    "test:coverage": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx,json,md}\" --write",
    "db:compare": "./scripts/comparar-schemas.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-security": "^2.1.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "src/**/*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
