@startuml Schema ECM - E-Commerce de Livros

!define Table(name,desc) class name as "name\n<size:10>desc</size>" << (T,#FFAAAA) >>
!define PK(name)  <b>name</b>
!define FK(name)  <i>name</i>
!define UK(name)  <color:blue>name</color>
!define CK(name)  <color:orange>name</color>
!define EX(name)  <color:purple>name</color>

' Paleta de pacotes
' #EFEFEF  referencia    #DDEEFF  usuario
' #DDFFD4  contato       #FFF5CC  endereco
' #FFE8D6  localizacao   #FFD6F0  cartao

' =============================================================================
' DOMÍNIO: REFERENCIA — tabelas de domínio sem dependências externas
' =============================================================================
package "referencia" #EFEFEF {

    Table(papeis, "Papéis de usuário") {
        PK(pap_id: SERIAL)
        UK(pap_descricao: VARCHAR(30))
        pap_criado_em: TIMESTAMPTZ
    }

    Table(tipos_telefones, "Tipos de telefone") {
        PK(tpt_id: SERIAL)
        UK(tpt_descricao: VARCHAR(30))
    }

    Table(tipos_logradouros, "Tipos de logradouro") {
        PK(tpl_id: SERIAL)
        UK(tpl_descricao: VARCHAR(50))
    }

    Table(tipos_residencias, "Tipos de residência") {
        PK(tpr_id: SERIAL)
        UK(tpr_descricao: VARCHAR(50))
    }

    Table(paises, "Países") {
        PK(pai_id: SERIAL)
        UK(pai_nome: VARCHAR(60))
    }

    Table(estados, "Estados brasileiros") {
        PK(est_id: SERIAL)
        UK(est_sigla: CHAR(2))
        UK(est_nome: VARCHAR(60))
        FK(pai_id: INTEGER)
    }

    Table(bandeiras_cartao, "Bandeiras de cartão — RN0025") {
        PK(ban_id: SERIAL)
        UK(ban_uuid: UUID)
        UK(ban_descricao: VARCHAR(30))
        ban_criado_em: TIMESTAMPTZ
    }
}

' =============================================================================
' DOMÍNIO: USUARIO — identidade, autenticação e perfil do cliente
' =============================================================================
package "usuario" #DDEEFF {

    Table(usuarios, "Usuários do sistema") {
        PK(usu_id: BIGSERIAL)
        UK(usu_uuid: UUID)
        usu_nome: VARCHAR(100)
        UK(usu_email: VARCHAR(255))
        UK(usu_cpf: VARCHAR(14))
        usu_senha: VARCHAR(255)
        FK(pap_id: INTEGER)
        usu_genero: VARCHAR(30)
        usu_nascimento: DATE
        usu_ativo: BOOLEAN  DEFAULT TRUE
        usu_criado_em: TIMESTAMPTZ
        usu_atualizado_em: TIMESTAMPTZ
    }

    Table(clientes, "Perfil detalhado do cliente") {
        PK(cli_id: BIGSERIAL)
        UK(cli_uuid: UUID)
        FK(usu_id: BIGINT)
        cli_ranking: INTEGER  DEFAULT 0
        cli_criado_em: TIMESTAMPTZ
        cli_atualizado_em: TIMESTAMPTZ
    }
}

' =============================================================================
' DOMÍNIO: CONTATO E LOCALIZAÇÃO — endereços e telefones
' =============================================================================
package "contato" #FFF5CC {

    Table(ceps, "Base de CEPs") {
        PK(cep_id: SERIAL)
        UK(cep_codigo: CHAR(8))
    }

    Table(cidades, "Cidades") {
        PK(cid_id: SERIAL)
        cid_nome: VARCHAR(80)
        FK(est_id: INTEGER)
    }

    Table(bairros, "Bairros") {
        PK(bai_id: SERIAL)
        bai_nome: VARCHAR(80)
        FK(cid_id: INTEGER)
    }

    Table(logradouros, "Logradouros") {
        PK(log_id: SERIAL)
        log_nome: VARCHAR(100)
        FK(tpl_id: INTEGER)
    }

    Table(telefones, "Telefones dos usuários") {
        PK(tel_id: BIGSERIAL)
        FK(usu_id: BIGINT)
        FK(tpt_id: INTEGER)
        tel_ddd: VARCHAR(3)
        tel_numero: VARCHAR(15)
        tel_criado_em: TIMESTAMPTZ
    }

    Table(enderecos, "Endereços dos usuários") {
        PK(end_id: BIGSERIAL)
        UK(end_uuid: UUID)
        FK(usu_id: BIGINT)
        end_apelido: VARCHAR(50)
        FK(tpr_id: INTEGER)
        FK(log_id: INTEGER)
        end_numero: VARCHAR(20)
        end_complemento: VARCHAR(100)
        FK(bai_id: INTEGER)
        FK(cep_id: INTEGER)
        end_cobranca: BOOLEAN DEFAULT FALSE
        end_entrega: BOOLEAN DEFAULT FALSE
        end_criado_em: TIMESTAMPTZ
    }
}

' =============================================================================
' DOMÍNIO: CARTAO — cartões de crédito do cliente
' =============================================================================
package "cartao" #FFD6F0 {

    Table(cartoes, "Cartões de crédito") {
        PK(crt_id: BIGSERIAL)
        UK(crt_uuid: UUID)
        FK(usu_id: BIGINT)
        FK(ban_id: INTEGER)
        UK(crt_token: VARCHAR(255))
        crt_final: VARCHAR(4)
        crt_nome_impresso: VARCHAR(100)
        crt_validade: DATE
        crt_principal: BOOLEAN DEFAULT FALSE
        crt_criado_em: TIMESTAMPTZ
        crt_atualizado_em: TIMESTAMPTZ
    }
}

' Relacionamentos
usuarios   "*" --> "1" papeis
clientes   "1" -- "1" usuarios
telefones  "*" --> "1" usuarios
telefones  "*" --> "1" tipos_telefones
enderecos  "*" --> "1" usuarios
enderecos  "*" --> "1" tipos_residencias
enderecos  "*" --> "1" logradouros
enderecos  "*" --> "1" bairros
enderecos  "*" --> "1" ceps
logradouros "*" --> "1" tipos_logradouros
bairros    "*" --> "1" cidades
cidades    "*" --> "1" estados
estados    "*" --> "1" paises
cartoes    "*" --> "1" usuarios
cartoes    "*" --> "1" bandeiras_cartao

@enduml
