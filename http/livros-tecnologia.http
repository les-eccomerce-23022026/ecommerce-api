### SQL para inserir autores, editoras e categorias necessários
### Execute este SQL no banco de dados antes de usar os comandos curl acima

-- Inserir autores
INSERT INTO autores (aut_nome, aut_descricao) VALUES
('Ethan Mollick', 'Professor da Wharton e autor do newsletter One Useful Thing, especialista em IA e inovação.'),
('Parmy Olson', 'Jornalista de tecnologia do Bloomberg, vencedora do Financial Times and Schroders Business Book of the Year Award.'),
('Yuval Noah Harari', 'Historiador e autor best-seller, conhecido por obras como Sapiens e Homo Deus.'),
('Aswath Damodaran', 'Professor da NYU e especialista em valuation, considerado o pai da avaliação moderna.'),
('Kara Swisher', 'Veterana jornalista de tecnologia, cofundadora da Recode e All Things D.'),
('Tom Davenport', 'Professor e autor especializado em analytics e inteligência artificial.'),
('Arvind Narayanan', 'Cientista da computação e professor de Princeton, especialista em IA e privacidade.'),
('Ray Kurzweil', 'Futurista e inventor, diretor de engenharia do Google, conhecido por suas previsões sobre IA.'),
('Tae Kim', 'Jornalista de tecnologia e autor especializado em negócios de tecnologia.'),
('David De Cremer', 'Professor e pesquisador especializado em liderança e transformação digital.')
ON CONFLICT DO NOTHING;

